def quick_analyze(engine: UniversalParadoxEngine, text: str, domain: Optional[str] = None) -> Dict[str, Any]:
    """Convenience function to run a quick analysis without widgets."""
    results = engine.analyze_text(text, domain)
    print(f"{results['status_icon']} {results['overall_status']} ({results['confidence']:.1%})")
    print(f"Domain: {results['domain']} | Claims: {results['claims']['total']} | "
          f"Evidence: {results['evidence_quality']['overall_score']:.2f}")
    if results['contradictions']:
        print(f"⚠️ {len(results['contradictions'])} internal contradictions detected")
    return results


def compare_theories(engine: UniversalParadoxEngine, *texts: str) -> None:
    """Compare multiple theories side by side using the quick analysis."""
    results = []
    for idx, text in enumerate(texts, 1):
        print(f"\n📋 Theory {idx}:")
        result = quick_analyze(engine, text)
        results.append(result)
    print("\n🏆 Comparison Summary:")
    best_confidence = max(r['confidence'] for r in results)
    best_evidence = max(r['evidence_quality']['overall_score'] for r in results)
    for idx, result in enumerate(results, 1):
        stars = ''
        if result['confidence'] == best_confidence:
            stars += '⭐'
        if result['evidence_quality']['overall_score'] == best_evidence:
            stars += '🌟'
        print(f"   Theory {idx}: {result['overall_status']} {stars}")


def domain_analysis_summary(engine: UniversalParadoxEngine) -> None:
    """Print a summary of the available domains and their characteristics."""
    print("🌐 Available Domains for Analysis:\n")
    for domain, info in engine.domain_patterns.items():
        print(f"🔹 {domain.title().replace('_', ' ')}")
        print(f"   Keywords: {', '.join(info['keywords'][:5])}...")
        print(f"   Evidence Types: {', '.join(info['evidence_types'])}")
        print(f"   Math Indicators: {len(info['math_indicators'])}")
        print()


