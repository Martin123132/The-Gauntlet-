def analyze_theory_interactive(engine: UniversalParadoxEngine) -> Tuple[widgets.Textarea, widgets.Dropdown, widgets.Output]:
    """Create an interactive widget interface for analysing theories.

    Parameters
    ----------
    engine : UniversalParadoxEngine
        Instance of the engine used to perform analyses.

    Returns
    -------
    Tuple[widgets.Textarea, widgets.Dropdown, widgets.Output]
        References to the text input, domain dropdown and output widget so
        advanced users can inspect or manipulate them.
    """
    # Domain selection dropdown
    domain_options = ['Auto-detect'] + list(engine.domain_patterns.keys()) + ['general']
    domain_widget = widgets.Dropdown(
        options=domain_options,
        value='Auto-detect',
        description='Domain:',
        style={'description_width': 'initial'}
    )

    # Optional slider for maximum claims
    max_claims_widget = widgets.IntSlider(
        value=engine.max_claims,
        min=1,
        max=20,
        step=1,
        description='Max Claims:',
        style={'description_width': 'initial'}
    )

    # Text input area
    text_widget = widgets.Textarea(
        value='',
        placeholder='Enter your theory, argument, or set of claims here...',
        description='Theory Text:',
        layout=widgets.Layout(width='100%', height='200px'),
        style={'description_width': 'initial'}
    )

    # Analyse button
    analyze_button = widgets.Button(
        description='🚀 ANALYZE FOR PARADOXES',
        button_style='success',
        layout=widgets.Layout(width='300px', height='45px')
    )

    output = widgets.Output()

    def on_analyze_click(_):
        with output:
            output.clear_output()
            if not text_widget.value.strip():
                print("❌ Please enter some text to analyse!")
                return
            print("🔄 Analysing theory for contradictions and paradoxes...\n")
            selected_domain = None if domain_widget.value == 'Auto-detect' else domain_widget.value
            results = engine.analyze_text(text_widget.value, selected_domain, max_claims_widget.value)
            display_results(results, text_widget.value)

    analyze_button.on_click(on_analyze_click)

    # Layout the widgets
    display(HTML("<h2>🌀 Universal Paradox Resolution Engine</h2>"))
    display(HTML("<p>Analyse claims across any domain for logical consistency and contradiction resolution</p>"))
    display(domain_widget)
    display(max_claims_widget)
    display(text_widget)
    display(analyze_button)
    display(output)

    return text_widget, domain_widget, output


