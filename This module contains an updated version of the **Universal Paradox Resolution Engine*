@dataclass
class ContradictionResult:
    """Container for the results of a contradiction analysis.

    Attributes
    ----------
    has_contradiction : bool
        Whether a contradiction was detected.
    contradiction_type : str
        A short label describing the type of contradiction.
    confidence : float
        Confidence score (0–1) for the detected contradiction.
    explanation : str
        Natural language explanation of the contradiction.
    evidence_quality : float
        A score (0–1) assessing the quality of evidence supporting the result.
    resolution_suggestions : List[str]
        A list of recommendations for resolving the contradiction.
    domain : str
        The domain (e.g. physics, legal) of the text analysed.
    """
    has_contradiction: bool
    contradiction_type: str
    confidence: float
    explanation: str
    evidence_quality: float
    resolution_suggestions: List[str]
    domain: str


@dataclass
class ClaimAnalysis:
    """Container for analysis of a single claim extracted from text.

    Attributes
    ----------
    claim_text : str
        The text of the claim.
    claim_type : str
        An identifier describing the type of claim (currently all claims are
        treated as "resolution_claim" since the engine aims at paradoxes).
    resolution_mechanism : str
        Indicates whether a mechanism is provided in the claim text.
    evidence_strength : float
        Numeric score (0–1) reflecting how much quantitative support exists.
    internal_consistency : float
        A heuristic measure of how internally consistent the claim is.
    status : str
        The result of the analysis: one of "resolved", "partial" or "failed".
    """
    claim_text: str
    claim_type: str
    resolution_mechanism: str
    evidence_strength: float
    internal_consistency: float
    status: str


