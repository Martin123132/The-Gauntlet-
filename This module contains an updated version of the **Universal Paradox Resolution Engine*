def display_results(results: Dict[str, Any], original_text: str) -> None:
    """Render the analysis results using HTML widgets.

    This helper generates a human-friendly summary of the overall status,
    claim analyses, evidence quality and any detected contradictions.  It does
    not store the results; storage is handled elsewhere in the module.

    Parameters
    ----------
    results : Dict[str, Any]
        The dictionary returned by ``UniversalParadoxEngine.analyze_text``.
    original_text : str
        The input text that was analysed (unused but accepted for compatibility).
    """
    status_colors = {'RESOLVES': '🟢', 'PARTIAL': '🟡', 'FAILS': '🔴'}
    color = status_colors.get(results['overall_status'], '⚪')

    display(HTML(f"""
    <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                color: white; padding: 20px; border-radius: 10px; margin: 20px 0;">
        <h2>{results['status_icon']} Analysis Results: {results['overall_status']}</h2>
        <p><strong>Domain:</strong> {results['domain'].title()}</p>
        <p><strong>Confidence:</strong> {results['confidence']:.1%}</p>
    </div>
