    # -------------------------------------------------------------------------
    # Domain detection
    # -------------------------------------------------------------------------
    def detect_domain(self, text: str) -> str:
        """Auto-detect the most likely domain of the input text.

        The method scores each known domain by counting the number of *unique*
        keywords and mathematical indicators present in the lower‑cased text.  The
        domain with the highest score is returned.  If no domain scores above
        zero, the fallback 'general' is used.

        Parameters
        ----------
        text : str
            Input text whose domain should be inferred.

        Returns
        -------
        str
            The name of the domain detected (or 'general' if none match).
        """
        text_lower = text.lower()
        domain_scores: Dict[str, int] = {}

        for domain, patterns in self.domain_patterns.items():
            unique_hits = set()
            # Score unique keyword matches
            for keyword in patterns['keywords']:
                if keyword in text_lower:
                    unique_hits.add(keyword)
            # Additional weight for mathematical indicators
            for indicator in patterns['math_indicators']:
                if indicator in text_lower:
                    unique_hits.add(indicator)
            domain_scores[domain] = len(unique_hits)

        # Return the highest scoring domain or 'general' if all are zero
        best_domain = max(domain_scores, key=domain_scores.get)
        if domain_scores[best_domain] == 0:
            return 'general'
        return best_domain

    # -------------------------------------------------------------------------
    # Claim extraction
    # -------------------------------------------------------------------------
    def extract_claims(self, text: str, max_claims: Optional[int] = None) -> List[str]:
        """Extract potential claims from a block of text.

        The text is split into sentences using punctuation.  Each sentence is
        examined for the presence of claim indicator words or certain logical
        connectors (e.g. 'therefore', 'because').  Only sentences longer than
        10 characters are considered.  The number of returned claims can be
        limited by specifying ``max_claims``; if omitted it falls back to
        ``self.max_claims``.

        Parameters
        ----------
        text : str
            The text from which to extract claims.
        max_claims : int, optional
            Maximum number of claims to return.  Defaults to the engine's
            ``max_claims`` attribute.

        Returns
        -------
        List[str]
            A list of sentence strings that are considered claims.
        """
        if max_claims is None:
            max_claims = self.max_claims

        sentences = re.split(r'[.!?]+', text)
        claims: List[str] = []

        for sentence in sentences:
            sentence_strip = sentence.strip()
            if len(sentence_strip) < 10:
                continue

            sent_lower = sentence_strip.lower()
            # Check for claim indicators
            if any(ind in sent_lower for ind in self.claim_indicators):
                claims.append(sentence_strip)
            else:
                # Check logical connectors via regex
                if any(pattern.search(sent_lower) for pattern in self.connector_patterns):
                    claims.append(sentence_strip)

            if len(claims) >= max_claims:
                break

        return claims

    # -------------------------------------------------------------------------
    # Evidence quality assessment
    # -------------------------------------------------------------------------
    def analyze_evidence_quality(self, text: str, domain: str) -> Dict[str, Any]:
        """Evaluate the quality of evidence present in the text.

        The analysis considers quantitative data (numbers), mathematical
        expressions, citations and domain‑specific evidence types.  Scores from
        each category contribute additively to an overall score capped at 1.0.

        Parameters
        ----------
        text : str
            The text being analysed.
        domain : str
            The domain the text belongs to.

        Returns
        -------
        Dict[str, Any]
            A dictionary containing the overall score and counts for each
            evidence component.
        """
        evidence_score = 0.3  # base score

        # Count numeric values (integers or floats)
        numbers = len(re.findall(r'\d+\.?\d*', text))
        if numbers > 0:
            evidence_score += min(0.25, numbers * 0.03)

        # Count mathematical content based on domain-specific indicators
        patterns = self.domain_patterns.get(domain, {})
        math_indicators = patterns.get('math_indicators', [])
        math_content = sum(1 for indicator in math_indicators if indicator in text)
        if math_content > 0:
            evidence_score += min(0.25, math_content * 0.08)

        # Count citations (year references, et al., according to)
        citations = len(re.findall(r'\([12]\d{3}\)|et al\.\b|according to', text, re.IGNORECASE))
        if citations > 0:
            evidence_score += min(0.2, citations * 0.05)

        # Count domain-specific evidence types
        evidence_types = patterns.get('evidence_types', [])
        domain_evidence = sum(1 for etype in evidence_types if etype.replace('_', ' ') in text.lower())
        if domain_evidence > 0:
            evidence_score += min(0.2, domain_evidence * 0.04)

        overall_score = min(1.0, evidence_score)
        return {
            'overall_score': overall_score,
            'quantitative_evidence': numbers,
            'mathematical_content': math_content,
            'citations': citations,
            'domain_specific': domain_evidence,
            'has_strong_evidence': overall_score >= 0.75
        }

    # -------------------------------------------------------------------------
    # Contradiction detection
    # -------------------------------------------------------------------------
    def check_internal_contradictions(self, text: str) -> List[Dict[str, Any]]:
        """Identify potential internal contradictions within a text.

        This heuristic method looks for pairs of sentences that express
        substantially the same content but differ in polarity (e.g. one uses
        negation and the other does not).  The overlap threshold has been
        tuned to reduce false positives.  At most five contradictions are
        returned.

        Parameters
        ----------
        text : str
            The text to inspect for contradictions.

        Returns
        -------
        List[Dict[str, Any]]
            A list of dictionaries describing each contradiction found.
        """
        contradictions: List[Dict[str, Any]] = []
        sentences = [s.strip().lower() for s in re.split(r'[.!?]+', text) if s.strip()]

        for i, sent1 in enumerate(sentences):
            for j, sent2 in enumerate(sentences[i + 1:], i + 1):
                # Check for differences in negation (presence of not/never/no)
                neg1 = any(word in sent1 for word in [' not ', 'never', 'no '])
                neg2 = any(word in sent2 for word in [' not ', 'never', 'no '])
                if neg1 == neg2:
                    continue  # both have or both lack negation

                # Compute word overlap (Jaccard similarity)
                words1 = set(sent1.split())
                words2 = set(sent2.split())
                intersection = words1 & words2
                union = words1 | words2
                overlap = len(intersection) / max(1, len(union))
                if overlap <= 0.3:
                    continue

                contradictions.append({
                    'type': 'Contradiction',
                    'sentence1': sent1.strip(),
                    'sentence2': sent2.strip(),
                    'confidence': overlap,
                    'explanation': 'Similar content with opposing polarity'
                })
                if len(contradictions) >= 5:
                    return contradictions

        return contradictions

    # -------------------------------------------------------------------------
    # Claim analysis
    # -------------------------------------------------------------------------
    def analyze_claims(self, claims: List[str], domain: str) -> List[ClaimAnalysis]:
        """Analyze a list of claims and classify their resolution status.

        The method assigns a simple evidence strength based on the presence of
        numeric values and explicit mention of mechanisms.  A claim is
        considered "resolved" if it both mentions a mechanism and has high
        evidence strength; "partial" if one of these is true; otherwise
        "failed".

        Parameters
        ----------
        claims : List[str]
            The claims extracted from the text.
        domain : str
            The domain of the text (unused here but retained for future
            extensions).

        Returns
        -------
        List[ClaimAnalysis]
            A list of ``ClaimAnalysis`` objects describing each claim.
        """
        claim_analyses: List[ClaimAnalysis] = []

        resolution_indicators = [' by ', ' through ', ' via ', ' using ', ' because ', ' since ', ' due to ']
        mechanism_words = ['mechanism', 'process', 'method', 'approach', 'framework', 'model']

        for claim in claims:
            claim_lower = claim.lower()

            # Determine whether the claim describes a mechanism
            has_mechanism = any(ind.strip() in claim_lower for ind in resolution_indicators)
            has_explicit_mechanism = any(word in claim_lower for word in mechanism_words)

            # Count numbers in the claim
            numbers_in_claim = len(re.findall(r'\d+\.?\d*', claim))
            evidence_strength = 0.4 + (numbers_in_claim * 0.1) + (0.2 if has_explicit_mechanism else 0)
            evidence_strength = min(0.95, evidence_strength)

            if has_mechanism and evidence_strength >= 0.7:
                status = 'resolved'
            elif has_mechanism or evidence_strength >= 0.6:
                status = 'partial'
            else:
                status = 'failed'

            claim_analyses.append(ClaimAnalysis(
                claim_text=claim[:100] + '...' if len(claim) > 100 else claim,
                claim_type='resolution_claim',
                resolution_mechanism='provided' if has_mechanism else 'missing',
                evidence_strength=evidence_strength,
                internal_consistency=0.8,
                status=status
            ))

        return claim_analyses

    # -------------------------------------------------------------------------
    # Top-level analysis
    # -------------------------------------------------------------------------
    def analyze_text(self, text: str, domain: Optional[str] = None, max_claims: Optional[int] = None) -> Dict[str, Any]:
        """Perform a complete paradox analysis on the supplied text.

        This orchestrates domain detection, claim extraction, evidence quality
        assessment, contradiction detection and summarisation.  The returned
        dictionary contains keys describing the overall outcome, details of
        claims, evidence, contradictions and a resolution ratio.

        Parameters
        ----------
        text : str
            The input text containing the theory or argument to analyse.
        domain : str, optional
            If supplied, overrides auto-detection of the domain.
        max_claims : int, optional
            Maximum number of claims to extract from the text.

        Returns
        -------
        Dict[str, Any]
            A dictionary summarising the analysis results.
        """
        if domain is None or domain == 'Auto-detect':
            domain = self.detect_domain(text)

        # Extract potential claims
        claims = self.extract_claims(text, max_claims)

        # Analyse each claim
        claim_analyses = self.analyze_claims(claims, domain)

        # Assess evidence
        evidence_quality = self.analyze_evidence_quality(text, domain)

        # Check contradictions
        contradictions = self.check_internal_contradictions(text)

        resolved_claims = [c for c in claim_analyses if c.status == 'resolved']
        partial_claims = [c for c in claim_analyses if c.status == 'partial']
        failed_claims = [c for c in claim_analyses if c.status == 'failed']

        total_claims = len(claim_analyses)
        resolution_ratio = len(resolved_claims) / max(1, total_claims)

        # Determine overall status
        if resolution_ratio >= 0.8 and evidence_quality['overall_score'] >= 0.6:
            overall_status = 'RESOLVES'
            status_icon = '✅'
        elif resolution_ratio >= 0.4:
            overall_status = 'PARTIAL'
            status_icon = '🎯'
        else:
            overall_status = 'FAILS'
            status_icon = '❌'

        confidence = min(1.0, 0.65 + (resolution_ratio * 0.25))

        return {
            'domain': domain,
            'overall_status': overall_status,
            'status_icon': status_icon,
            'confidence': confidence,
            'claims': {
                'total': total_claims,
                'resolved': len(resolved_claims),
                'partial': len(partial_claims),
                'failed': len(failed_claims),
                'analyses': claim_analyses
            },
            'evidence_quality': evidence_quality,
            'contradictions': contradictions,
            'resolution_ratio': resolution_ratio
        }


